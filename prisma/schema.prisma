generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CashEntryType {
  IN
  OUT
}

enum CashPaymentMethod {
  CASH
  PIX
  CARD
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  company      String   @default("Sem empresa")
  passwordHash String
  createdAt    DateTime @default(now())
}

model Credential {
  id           String   @id @default(uuid())
  name         String
  username     String
  passwordHash String
  createdAt    DateTime @default(now())
}

model CashEntry {
  id            String            @id @default(uuid())
  company       String            @default("Sem empresa")
  type          CashEntryType
  paymentMethod CashPaymentMethod
  amount        Float
  description   String
  category      String?
  createdAt     DateTime          @default(now())
}
